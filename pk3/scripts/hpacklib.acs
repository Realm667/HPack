// ------------------------------------------------------------------------------------------------

Function int GetVelocity (void)
{
    int vel;
    int x = GetActorVelX(0);
    int y = GetActorVelY(0);
    int angle = VectorAngle(x, y);

    If(((angle + 0.125) % 0.5) > 0.25)
        vel = FixedDiv(y, Sin(angle));
    Else
        vel = FixedDiv(x, Cos(angle));

    return vel >> 16;
}

// ------------------------------------------------------------------------------------------------

Script "HPKS_FootSteps" Enter
{
    int delayTime, stepVolume;

    While(TRUE)
    {
        If(GetCVar("hpack_fstep_enable"))
        {
            delayTime = FixedMul(16 - GetVelocity() / 2, GetCVar("hpack_fstep_delaymul"));
            stepVolume = FixedMul(GetCVar("hpack_fstep_volmul"), GetVelocity() * 127 / 15);

            If(GetActorZ(0) - GetActorFloorZ(0) == 0)
            {
                For(int i = 0; StrIcmp(hpka_floorTexture[i][HPKC_FTSTEP_TEXNAME], "-EndOfList-"); i++)
                {
                    If(CheckActorFloorTexture(0, hpka_floorTexture[i][HPKC_FTSTEP_TEXNAME]))
                    {
                        ActivatorSound(hpka_floorTexture[i][HPKC_FTSTEP_STEPSOUND], stepVolume);
                        Break;
                    }
                }
            }
        }

        If(delayTime < 1)
            Delay(1);
        Else
            Delay(delayTime);
    }
}